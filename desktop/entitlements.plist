<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Hardened-runtime entitlements for the notarized docuchat.app (P2.7).
     PyInstaller-frozen Python + PyTorch need JIT/unsigned-memory/library-validation
     relaxations to run under the hardened runtime; these are the standard minimal set
     for a Python app and add NO sandbox exceptions, network servers, or device access. -->
<plist version="1.0">
<dict>
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
